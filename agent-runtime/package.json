{
  "name": "@containarium/agent-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "In-box agent loop for Containarium agent-skills (Phase 4a). Engine-pluggable: Claude Agent SDK, OpenAI Codex SDK, or Google Gen AI SDK (Gemini), driving the in-box agent-box MCP server.",
  "type": "module",
  "bin": {
    "agent-runtime": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.169",
    "@google/genai": "^2.8.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "^0.138.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
